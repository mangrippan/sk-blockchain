# Ignore node_modules
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore development files
.env
.env.local
.env.development
.env.test

# Ignore dist folder (will be rebuilt in Docker)
dist
dist-ssr

# Ignore logs
logs
*.log

# Ignore IDE/editor files
.vscode
.idea
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore git files
.git
.gitignore

# Ignore documentation
README.md
*.md
docs/

# Ignore other unnecessary files
.editorconfig
.prettierrc
.eslintrc*
vite.config.js.timestamp-*

# Ignore test files (if any)
__tests__
*.test.js
*.spec.js
