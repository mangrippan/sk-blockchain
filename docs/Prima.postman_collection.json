{
	"info": {
		"_postman_id": "prima-api-v1",
		"name": "Prima API - MVP",
		"description": "API endpoints for Prima - Blockchain-based Faculty Promotion System\n\nBase URL: http://localhost:3000\n\n## Authentication\nMost endpoints require JWT token in Authorization header:\n```\nAuthorization: Bearer <token>\n```\n\nGet token from /api/v1/auth/login endpoint.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nip\": \"199999012021031099\",\n  \"nama\": \"Test Dosen\",\n  \"email\": \"test@prima.test\",\n  \"password\": \"Password123!\",\n  \"role\": \"dosen\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Register a new user account"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('jwt_token', response.token);",
									"    pm.environment.set('user_id', response.user.id);",
									"    pm.environment.set('user_role', response.user.role);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test.dosen@test.com\",\n  \"password\": \"Test123!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Login and get JWT token. Token is automatically saved to environment variable."
					}
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "me"]
						},
						"description": "Get current authenticated user information"
					}
				}
			]
		},
		{
			"name": "Kegiatan (Activities)",
			"item": [
				{
					"name": "Get All Kegiatan",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan"]
						},
						"description": "Get all kegiatan for current user (dosen sees their own, admin sees all)"
					}
				},
				{
					"name": "Get Kegiatan by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "{{kegiatan_id}}"
								}
							]
						},
						"description": "Get specific kegiatan by ID"
					}
				},
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan/stats/dashboard",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan", "stats", "dashboard"]
						},
						"description": "Get dashboard statistics (total kegiatan, KUM points, verification status)"
					}
				},
				{
					"name": "Create Kegiatan",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('kegiatan_id', response.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "ref_kegiatan_id",
									"value": "1",
									"type": "text",
									"description": "Reference kegiatan type ID"
								},
								{
									"key": "deskripsi",
									"value": "Publikasi jurnal internasional Q2 - Blockchain in Education",
									"type": "text",
									"description": "Activity description"
								},
								{
									"key": "file",
									"type": "file",
									"src": [],
									"description": "Supporting document (PDF, JPG, PNG)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan"]
						},
						"description": "Upload new kegiatan with supporting document. Kegiatan ID is automatically saved."
					}
				},
				{
					"name": "Verify Kegiatan (Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"verified\",\n  \"catatan\": \"Dokumen lengkap dan valid\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan/:id/verify",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan", ":id", "verify"],
							"variable": [
								{
									"key": "id",
									"value": "{{kegiatan_id}}"
								}
							]
						},
						"description": "Verify or reject kegiatan (Admin/Pimpinan only). Status: 'verified' or 'rejected'"
					}
				},
				{
					"name": "Delete Kegiatan",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "{{kegiatan_id}}"
								}
							]
						},
						"description": "Soft delete kegiatan (owner or admin only)"
					}
				},
				{
					"name": "Get Kegiatan Audit Trail",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/kegiatan/:id/audit",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "kegiatan", ":id", "audit"],
							"variable": [
								{
									"key": "id",
									"value": "{{kegiatan_id}}"
								}
							]
						},
						"description": "Get audit trail history for a kegiatan"
					}
				}
			]
		},
		{
			"name": "Usulan Kenaikan Pangkat",
			"item": [
				{
					"name": "Get All Usulan",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/usulan",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan"]
						},
						"description": "Get all promotion proposals (filtered by role)"
					}
				},
				{
					"name": "Get Usulan by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/usulan/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "{{usulan_id}}"
								}
							]
						},
						"description": "Get specific usulan by ID with full details"
					}
				},
				{
					"name": "Create Usulan",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('usulan_id', response.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"pangkat_tujuan\": \"Lektor Kepala\",\n  \"golongan_tujuan\": \"IV/b\",\n  \"kegiatan_ids\": [\n    \"{{kegiatan_id}}\"\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/usulan",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan"]
						},
						"description": "Create new promotion proposal (Dosen only). Usulan ID is saved automatically."
					}
				},
				{
					"name": "Proses Usulan (Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"catatan\": \"Usulan memenuhi syarat dan akan diproses lebih lanjut\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/usulan/:id/proses",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan", ":id", "proses"],
							"variable": [
								{
									"key": "id",
									"value": "{{usulan_id}}"
								}
							]
						},
						"description": "Process usulan - change status to 'sedang_diproses' (Admin/Pimpinan only)"
					}
				},
				{
					"name": "Tolak Usulan (Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"alasan\": \"Total poin KUM belum mencukupi syarat minimum\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/usulan/:id/tolak",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan", ":id", "tolak"],
							"variable": [
								{
									"key": "id",
									"value": "{{usulan_id}}"
								}
							]
						},
						"description": "Reject usulan with reason (Admin/Pimpinan only)"
					}
				},
				{
					"name": "Terbitkan SK (Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "nomor_sk",
									"value": "SK/001/2026",
									"type": "text"
								},
								{
									"key": "tanggal_sk",
									"value": "2026-05-17",
									"type": "text"
								},
								{
									"key": "sk_document",
									"type": "file",
									"src": [],
									"description": "SK document file (PDF)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/usulan/:id/terbitkan-sk",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan", ":id", "terbitkan-sk"],
							"variable": [
								{
									"key": "id",
									"value": "{{usulan_id}}"
								}
							]
						},
						"description": "Issue SK document for approved usulan (Admin/Pimpinan only)"
					}
				},
				{
					"name": "Get Usulan Audit Trail",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/usulan/:id/audit",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "usulan", ":id", "audit"],
							"variable": [
								{
									"key": "id",
									"value": "{{usulan_id}}"
								}
							]
						},
						"description": "Get audit trail for usulan"
					}
				}
			]
		},
