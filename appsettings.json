{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Error",
      "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "None",
      "System.Net": "Warning",
      "SriPayroll": "Information"
    },
    "GELF": {
      "Host": "#{gelf-host}#",
      "Port": 12201,
      "Protocol": "UDP",
      "LogSource": "#{gelf-logsource}#"
    }
  },
  "ConnectionStrings": {
    "DbPayroll": "#{connectionstrings-dbpayroll}#",
    "Dbi": "#{connectionstrings-dbi}#"
  },
  "Ldap": {
    "Host": "#{ldap-host}#",
    "Port": "#{ldap-port}#",
    "BaseDn": "#{ldap-basedn}#",
    "Filter": "uid={0}"
  },
  "Jwt": {
    "Key": "#{jwt-key}#",
    "Issuer": "#{jwt-issuer}#",
    "Audience": "#{jwt-audience}#",
    "ExpiryInMinutes": "#{jwt-expiryinminutes}#"
  },
  "Minio": {
    "Protocol": "#{minio-protocol}#",
    "Host": "#{minio-host}#",
    "AccessKey": "#{minio-accesskey}#",
    "SecretKey": "#{minio-secretkey}#",
    "Bucket": "#{minio-bucket}#"
  },
  "ReportServer": {
    "BaseUrl": "#{reportserver-baseurl}#",
    "Username": "#{reportserver-username}#",
    "Password": "#{reportserver-password}#"
  }
}
