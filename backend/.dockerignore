# Ignore node_modules
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore development files
.env
.env.local
.env.development
.env.test

# Ignore test files
__tests__
__mocks__
*.test.js
test-*.js
fix-*.js
seed-*.js

# Ignore logs
logs
*.log

# Ignore uploaded files (these should be in volumes)
uploads/*
!uploads/.gitkeep

# Ignore IDE/editor files
.vscode
.idea
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore git files
.git
.gitignore

# Ignore documentation
README.md
*.md
docs/

# Ignore other unnecessary files
.editorconfig
.prettierrc
.eslintrc*
jest.config.js
