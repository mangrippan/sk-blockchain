# ============================================
# ChainRank Backend Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file to Git!

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection settings
# NOTE: Port 5434 is used for Docker to avoid conflicts with local PostgreSQL (default 5432)
DB_HOST=localhost
DB_PORT=5434
DB_NAME=chainrank_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10
DB_SSL=false
DB_SCHEMA=sk

# ============================================
# JWT Configuration
# ============================================
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER use the example value in production!
JWT_SECRET=generate_your_own_secret_minimum_32_characters_long
JWT_EXPIRES_IN=24h

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
# Frontend URL (Vue.js Vite default port is 5173)
CORS_ORIGIN=http://localhost:5173

# ============================================
# Hyperledger Fabric Configuration
# ============================================
# Set to 'true' to enable blockchain features
# Set to 'false' to run in database-only mode (fallback mode)
FABRIC_ENABLED=true

# Fabric network settings (must match fabric-network/ configuration)
FABRIC_CHANNEL=skchannel
FABRIC_CHAINCODE=chainrank

# Path to Fabric connection profile (relative to backend/)
FABRIC_CONNECTION_PROFILE=../fabric-config/connection-org1.json

# Path to wallet directory (relative to backend/)
FABRIC_WALLET_PATH=../fabric-config/wallet

# ============================================
# File Upload Configuration (Optional)
# ============================================
# Max file size in bytes (default: 5MB)
# MAX_FILE_SIZE=5242880

# Allowed file types (default: pdf only)
# ALLOWED_FILE_TYPES=application/pdf

# Upload directory (default: ./uploads)
# UPLOAD_DIR=./uploads

# ============================================
# Logging Configuration (Optional)
# ============================================
# Log level: error, warn, info, debug
# LOG_LEVEL=info

# ============================================
# Production Settings
# ============================================
# Uncomment and configure for production deployment:
# NODE_ENV=production
# DB_SSL=true
# DB_POOL_SIZE=20
# JWT_EXPIRES_IN=2h
# CORS_ORIGIN=https://your-production-domain.com
# FABRIC_ENABLED=true

