# Database Configuration (Remote Server)
DB_HOST=your_server_host_or_ip
DB_PORT=5432
DB_NAME=chainrank_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_POOL_SIZE=10
DB_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-too
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=application/pdf

# Hyperledger Fabric Configuration
FABRIC_CHANNEL=skchannel
FABRIC_CHAINCODE=kegiatan
FABRIC_MSP_ID=Org1MSP
FABRIC_WALLET_PATH=./wallet
FABRIC_CONNECTION_PROFILE=./connection-profile/connection-org1.json
FABRIC_USER_ID=appUser

# Encryption (for sensitive data like NIP/NIK)
ENCRYPTION_SECRET=your-encryption-secret-32-chars-min

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
